rules_version = '2';

// App de un solo usuario: solo la cuenta de Google dueña de estos datos puede leer/escribir.
// Cambia el correo si usas una cuenta distinta a la del ejemplo.
// Los scripts de seed / análisis diario usan el Admin SDK y no pasan por estas reglas.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.email == 'javier.villalba.89@gmail.com';
    }
  }
}
