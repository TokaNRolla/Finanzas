rules_version = '2';

// App de un solo usuario: cualquier request autenticado es el dueño de los datos.
// Los scripts de seed / análisis diario usan el Admin SDK y no pasan por estas reglas.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
