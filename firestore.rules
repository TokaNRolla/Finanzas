rules_version = '2';

// App de un solo usuario: solo tú puedes crear cuentas (no hay registro público
// dentro de la app), así que cualquier request autenticado es válido.
// Los scripts de seed / análisis diario usan el Admin SDK y no pasan por estas reglas.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
